# Copy this file to `.env` and fill in your real keys.
# `.env` is gitignored. The CLI loads it automatically; the library doesn't.
# Existing shell-exported env vars take precedence over values in .env.

# Required for the default LLM (xAI Grok 4.20).
# Get one at https://console.x.ai/
XAI_API_KEY=

# Required when `tavily_search` or `tavily_extract` is enabled (both are by default).
# Get one at https://app.tavily.com/ — free tier ~1k credits/month.
TAVILY_API_KEY=

# Required only when `apify_instagram` / `apify_linkedin` / `apify_twitter` is enabled.
# Get one at https://console.apify.com/account/integrations
APIFY_TOKEN=

# Optional: only set if swapping the LLM. The CLI also reads OSINT_LLM_*
# env vars (below) so you don't have to pass --llm-* flags every invocation.
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# ─── Optional: default LLM swap via env (CLI flags still override) ─────────────
# Uncomment + fill these to make a different model your default. Precedence:
#   --llm-* CLI flag > OSINT_LLM_* env var > Grok 4.20 hardcoded default.
#
# Example for OpenAI GPT-5:
# OSINT_LLM_MODEL=gpt-5
# OSINT_LLM_BASE_URL=https://api.openai.com/v1
# OSINT_LLM_API_KEY_ENV=OPENAI_API_KEY
# OSINT_LLM_INPUT_MTOK_USD=2.50
# OSINT_LLM_OUTPUT_MTOK_USD=10.0
#
# Example for DeepSeek Chat:
# OSINT_LLM_MODEL=deepseek-chat
# OSINT_LLM_BASE_URL=https://api.deepseek.com/v1
# OSINT_LLM_API_KEY_ENV=DEEPSEEK_API_KEY
# OSINT_LLM_INPUT_MTOK_USD=0.27
# OSINT_LLM_OUTPUT_MTOK_USD=1.10
#
# Example for local Ollama (any value works as the key — ChatOpenAI wants one):
# OSINT_LLM_MODEL=qwen2.5:32b
# OSINT_LLM_BASE_URL=http://localhost:11434/v1
# OSINT_LLM_API_KEY_ENV=OLLAMA_KEY
# OLLAMA_KEY=ignored
# OSINT_LLM_INPUT_MTOK_USD=0
# OSINT_LLM_OUTPUT_MTOK_USD=0
