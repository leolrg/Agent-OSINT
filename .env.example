# Copy this file to `.env` and fill in your real keys.
# `.env` is gitignored. The CLI loads it automatically; the library doesn't.
# Existing shell-exported env vars take precedence over values in .env.

# Required for the default LLM (xAI Grok 4.20).
# Get one at https://console.x.ai/
XAI_API_KEY=

# Required when `tavily_search` or `tavily_extract` is enabled (both are by default).
# Get one at https://app.tavily.com/ — free tier ~1k credits/month.
TAVILY_API_KEY=

# Required only when `apify_instagram` / `apify_linkedin` / `apify_twitter` is enabled.
# Get one at https://console.apify.com/account/integrations
APIFY_TOKEN=

# Optional: only set if swapping the LLM via --llm-model + --llm-api-key-env.
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
