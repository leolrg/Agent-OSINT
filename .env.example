# ============================================================
# Local development env file. Copy to `.env` and fill in.
# Production values come from AWS Secrets Manager (Phase 3).
# ============================================================

# --- LLM keys (real, used by the agent inside the worker) ---
OPENAI_API_KEY=sk-replace-me
XAI_API_KEY=xai-replace-me
APIFY_TOKEN=apify_api_replace_me

# --- Auth (Phase 2 only; harmless for Phase 1) ---
NEXTAUTH_SECRET=local-dev-secret-change-me-32-bytes-min
NEXTAUTH_URL=http://localhost:3000
MAX_CONCURRENT_SCANS_PER_USER=2

# --- Postgres ---
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/agent_osint
# Drizzle uses postgres:// (no driver), so a separate var:
DATABASE_URL_NODE=postgresql://app:app@localhost:5432/agent_osint

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- LocalStack (S3 + SQS) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET=agent-osint-local-results
SQS_QUEUE_URL=http://localhost:4566/000000000000/agent-osint-scans

# --- Worker tuning ---
LOG_LEVEL=INFO
SCAN_VISIBILITY_TIMEOUT_SECONDS=5400  # 90 min
SCAN_HEARTBEAT_SECONDS=300            # 5 min

# --- CLI-only: optional LLM swap ---
# These vars only affect the CLI runner; the worker uses OPENAI_API_KEY /
# XAI_API_KEY directly via langchain-openai's defaults.
# The CLI loads this file automatically; the library doesn't.
# Existing shell-exported env vars take precedence over values in .env.
#
# Optional: only set if swapping the LLM. The CLI also reads OSINT_LLM_*
# env vars (below) so you don't have to pass --llm-* flags every invocation.
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# ─── Optional: default LLM swap via env (CLI flags still override) ─────────────
# Uncomment + fill these to make a different model your default. Precedence:
#   --llm-* CLI flag > OSINT_LLM_* env var > Grok 4.20 hardcoded default.
#
# Example for OpenAI GPT-5:
# OSINT_LLM_MODEL=gpt-5
# OSINT_LLM_BASE_URL=https://api.openai.com/v1
# OSINT_LLM_API_KEY_ENV=OPENAI_API_KEY
# OSINT_LLM_INPUT_MTOK_USD=2.50
# OSINT_LLM_OUTPUT_MTOK_USD=10.0
#
# Example for DeepSeek Chat:
# OSINT_LLM_MODEL=deepseek-chat
# OSINT_LLM_BASE_URL=https://api.deepseek.com/v1
# OSINT_LLM_API_KEY_ENV=DEEPSEEK_API_KEY
# OSINT_LLM_INPUT_MTOK_USD=0.27
# OSINT_LLM_OUTPUT_MTOK_USD=1.10
#
# Example for local Ollama (any value works as the key — ChatOpenAI wants one):
# OSINT_LLM_MODEL=qwen2.5:32b
# OSINT_LLM_BASE_URL=http://localhost:11434/v1
# OSINT_LLM_API_KEY_ENV=OLLAMA_KEY
# OLLAMA_KEY=ignored
# OSINT_LLM_INPUT_MTOK_USD=0
# OSINT_LLM_OUTPUT_MTOK_USD=0
